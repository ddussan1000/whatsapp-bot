PORT=3000
LOG_LEVEL=info

# CORS — orígenes del dashboard separados por coma (dejar vacío = solo dev local)
ALLOWED_ORIGINS=https://app.dssbot.site,https://dssbot.site

# Supabase (en el API backend usar service_role; la anon key sin JWT en servidor suele romper RLS)
SUPABASE_URL=
SUPABASE_KEY=
# Opcional: si está definida, se usa solo para el API (recomendado en Railway)
SUPABASE_SERVICE_ROLE_KEY=

# IA — al menos uno para respuestas libres (sin ninguno: "modo pruebas")
AI_PROVIDER=auto
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Redis (false = usa memoria local, suficiente para pruebas)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Dashboard auth
DASHBOARD_SECRET=cambia_esto_por_un_string_seguro

# URL pública del API (https://…). En Railway/Vercel suele inferirse con X-Forwarded-Proto;
# si el webhook URL sale como http://, define esto explícitamente.
PUBLIC_BASE_URL=

# Alertas por Telegram (opcional)
ADMIN_PHONE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email — Resend (https://resend.com)
# Sin dominio propio usa onboarding@resend.dev (solo para pruebas)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
# URL pública del dashboard frontend (para links de invitación)
DASHBOARD_PUBLIC_URL=https://tu-dashboard.vercel.app

# Storage
STORAGE_MODE=supabase
SUPABASE_STORAGE_BUCKET_RECEIPTS=receipts
SUPABASE_STORAGE_BUCKET_FLOW_MEDIA=flow-media
RECEIPT_RETENTION_DAYS=7
OCR_PROVIDER=tesseract
