PORT=3000
LOG_LEVEL=info

# Meta WhatsApp Cloud API
# Fallback global — puede configurarse por instancia desde el panel
META_TOKEN=
META_PHONE_ID=
VERIFY_TOKEN=

# Supabase (usar service_role key, NO la anon key)
SUPABASE_URL=
SUPABASE_KEY=

# IA — al menos uno para respuestas libres (sin ninguno: "modo pruebas")
AI_PROVIDER=auto
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Redis (false = usa memoria local, suficiente para pruebas)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Dashboard auth
DASHBOARD_SECRET=cambia_esto_por_un_string_seguro

# URL pública del API (https://…). En Railway/Vercel suele inferirse con X-Forwarded-Proto;
# si el webhook URL sale como http://, define esto explícitamente.
PUBLIC_BASE_URL=

# Alertas por Telegram (opcional)
ADMIN_PHONE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Storage
STORAGE_MODE=supabase
SUPABASE_STORAGE_BUCKET_RECEIPTS=receipts
SUPABASE_STORAGE_BUCKET_FLOW_MEDIA=flow-media
RECEIPT_RETENTION_DAYS=7
OCR_PROVIDER=tesseract
